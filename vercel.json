{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": {
        "service": "web",
        "path": "/index.html"
      }
    },
    {
      "source": "/eve/v1/:path*",
      "destination": {
        "service": "eve"
      }
    },
    {
      "source": "/:path*",
      "destination": {
        "service": "web"
      }
    }
  ],
  "services": {
    "web": {
      "root": ".",
      "framework": "nuxtjs"
    },
    "eve": {
      "buildCommand": "eve build",
      "framework": "eve",
      "root": "."
    }
  }
}
