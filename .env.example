# Core authentication
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000
INTERNAL_API_SECRET=replace-with-at-least-32-random-characters
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated Better Auth user IDs, verified emails, or E.164 phone numbers
# allowed to manage /admin. Use your E.164 phone for first-admin bootstrap.
WAITLIST_ADMIN_IDENTIFIERS=

# PostgreSQL. Leave unset locally to use PGlite.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Photon Cloud iMessage. Use these Spectrum names from the Photon dashboard.
IMESSAGE_LOCAL=false
SPECTRUM_PROJECT_ID=
SPECTRUM_PROJECT_SECRET=
SPECTRUM_SIGNING_SECRET=

# Photon cloud webhooks currently guarantee text and attachment events only.
# Leave native onboarding polls disabled until poll_option webhook delivery is enabled for the project.
PHOTON_NATIVE_POLL_EVENTS_ENABLED=false

# The Chat SDK adapter names below are supported aliases. Do not set both sets.
# IMESSAGE_PROJECT_ID=
# IMESSAGE_PROJECT_SECRET=
# IMESSAGE_WEBHOOK_SECRET=

# Chat SDK Redis state. Vercel Marketplace may provide KV_URL instead.
# REDIS_URL=rediss://default:password@host:port
# KV_URL=rediss://default:password@host:port

# Upstash REST cache for Mem0 recall
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Mem0 Cloud
MEM0_API_KEY=
# MEM0_API_URL=https://api.mem0.ai

# Resend recovery email
RESEND_API_KEY=
AUTH_EMAIL_FROM=admin@cynevra.com

# Optional when the Eve service uses a different origin in development.
# EVE_INTERNAL_URL=http://localhost:3000

# Optional Eve live eval inputs. Never commit a real cookie or webhook secret.
# EVAL_BETTER_AUTH_COOKIE=__Secure-better-auth.session_token=...
# EVAL_IMESSAGE_PHONE_NUMBER=+15551234567
# EVAL_IMESSAGE_WEBHOOK_SECRET=...
